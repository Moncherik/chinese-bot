# ============================================================
# Production .env — copy to .env on the server and fill values.
# ============================================================

APP_NAME="Chinese App"
APP_ENV=production
APP_KEY=base64:PASTE_GENERATED_KEY_HERE
APP_DEBUG=false
# Your server's public URL (use its IP or a domain).
APP_URL=http://YOUR.SERVER.IP:8000

# --- Database (PostgreSQL container) ---
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=chinese_learn
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# --- Telegram ---
TELEGRAM_TOKEN=YOUR_BOTFATHER_TOKEN
# Random string in the webhook URL — protects the endpoint.
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_RANDOM_STRING

# On a server api.telegram.org is reachable directly → no proxy.
TELEGRAM_PROXY=

# Queue + cache (use DB to keep it simple, no Redis needed).
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database
